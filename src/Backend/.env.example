# TicketRadar - Environment Configuration Template
# Copy this file to '.env' and fill in your values.

# SMTP Configuration (Required for Email notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# Optional Scraper Custom Settings
# DEFAULT_CHECK_INTERVAL=30

# Security Settings (Set to true to disable reCAPTCHA and App Check for Self-Hosted / On-Premise / Running from Source Code)
DISABLE_SECURITY=false

# reCAPTCHA Configuration
RECAPTCHA_SITE=xxx
RECAPTCHA_SECRET=xxx

# Firebase Configuration (Required for authentication and authorization)
FIREBASE_TYPE=service_account
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_content\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=your_client_x509_cert_url
FIREBASE_UNIVERSE_DOMAIN=googleapis.com

# Admin Discord Webhook Notification URL
ADMIN_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Google Cloud Logging Configuration
GCP_LOGGING_TYPE=service_account
GCP_LOGGING_PROJECT_ID=your_gcp_project_id
GCP_LOGGING_PRIVATE_KEY_ID=your_private_key_id
GCP_LOGGING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_content\n-----END PRIVATE KEY-----\n"
GCP_LOGGING_CLIENT_EMAIL=your_gcp_client_email
GCP_LOGGING_CLIENT_ID=your_client_id
GCP_LOGGING_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GCP_LOGGING_TOKEN_URI=https://oauth2.googleapis.com/token
GCP_LOGGING_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GCP_LOGGING_CLIENT_X509_CERT_URL=your_client_x509_cert_url
GCP_LOGGING_UNIVERSE_DOMAIN=googleapis.com

